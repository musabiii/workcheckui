<Window x:Class="WorkCheck.Views.StatisticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Статистика"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Width="500" Height="400">

    <Border Background="#1E1E2E" CornerRadius="12"
            BorderBrush="#33FFFFFF" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="16" Opacity="0.4" ShadowDepth="2"/>
        </Border.Effect>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="◀" Click="OnPreviousDayClick" Cursor="Hand"
                        Padding="10,4" FontSize="14" FontWeight="Bold"
                        Style="{StaticResource CloseButton}"/>

                <TextBlock Grid.Column="1" x:Name="DateText" Text="05.03.2026" Foreground="#A6E3A1"
                           FontSize="18" FontWeight="Bold"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Margin="12,0"/>

                <Button Grid.Column="2" Content="▶" Click="OnNextDayClick" Cursor="Hand"
                        Padding="10,4" FontSize="14" FontWeight="Bold"
                        Style="{StaticResource CloseButton}"/>

                <Button Grid.Column="4" Content="✕" Click="OnCloseClick" Cursor="Hand"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Style="{StaticResource CloseButton}"/>
            </Grid>

            <!-- Summary -->
            <Border Grid.Row="1" Background="#181825" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Всего сессий" Foreground="#6C7086" FontSize="12"/>
                            <TextBlock x:Name="SessionCountText" Text="0" Foreground="#CDD6F4"
                                       FontSize="24" FontWeight="Bold" Margin="0,4,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Text="Общее время" Foreground="#6C7086" FontSize="12"/>
                            <TextBlock x:Name="TotalTimeText" Text="0 мин" Foreground="#A6E3A1"
                                       FontSize="24" FontWeight="Bold" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Сессии:" Foreground="#6C7086" FontSize="12" Margin="0,0,0,8"/>

                    <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                        <DataGrid x:Name="SessionsGrid" AutoGenerateColumns="False" 
                                  Background="Transparent" BorderThickness="0"
                                  RowBackground="Transparent" AlternatingRowBackground="#11111A"
                                  HeadersVisibility="Column"
                                  CanUserAddRows="False" CanUserDeleteRows="False"
                                  CanUserResizeRows="False" CanUserReorderColumns="False"
                                  IsReadOnly="True"
                                  Foreground="#CDD6F4">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#313244"/>
                                    <Setter Property="Foreground" Value="#A6ADC8"/>
                                    <Setter Property="Padding" Value="8,6"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="8,6"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="Foreground" Value="#CDD6F4"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#45475A"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.CellStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Начало" Binding="{Binding StartTime, StringFormat={}{0:HH:mm}}" Width="70"/>
                                <DataGridTextColumn Header="Конец" Binding="{Binding EndTime, StringFormat={}{0:HH:mm}}" Width="70"/>
                                <DataGridTextColumn Header="Длительность" Binding="{Binding DurationText}" Width="90"/>
                                <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <!-- Footer -->
            <Button Grid.Row="2" Content="Закрыть" Click="OnCloseClick"
                    HorizontalAlignment="Stretch" Padding="12,8"
                    FontSize="14" Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="BtnBorder" Background="#45475A" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="BtnBorder" Property="Background" Value="#585B70"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Border>
</Window>
